        "\n",
        "// ── PRICE CALCULATOR ──\n",
        "function calcPrice(){\n",
        "  const svc=document.getElementById('calc-service').value\n",
        "  const dist=parseFloat(document.getElementById('calc-dist').value)||0\n",
        "  const weight=parseFloat(document.getElementById('calc-weight').value)||0\n",
        "  const ins=document.getElementById('ins').checked\n",
        "  const express=document.getElementById('express').checked\n",
        "  const sms=document.getElementById('sms').checked\n",
        "  const cod=document.getElementById('cod').checked\n",
        "\n",
        "  let base=0,rateKm=0,rateKg=0\n",
        "  if(svc==='local'){base=1500;rateKm=50;rateKg=200}\n",
        "  else if(svc==='interstate'){base=3500;rateKm=80;rateKg=300}\n",
        "  else{base=15000;rateKm=150;rateKg=500}\n",
        "\n",
        "  document.getElementById('dist-group').style.display=svc==='international'?'none':'block'\n",
        "\n",
        "  const distFee=svc==='international'?0:Math.round(dist*rateKm)\n",
        "  const weightFee=Math.round(weight*rateKg)\n",
        "  let addons=0\n",
        "  if(ins)addons+=500;if(express)addons+=1000;if(sms)addons+=200;if(cod)addons+=400\n",
        "\n",
        "  document.getElementById('r-base').textContent='₦'+base.toLocaleString()\n",
        "  document.getElementById('r-dist').textContent='₦'+distFee.toLocaleString()\n",
        "  document.getElementById('r-weight').textContent='₦'+weightFee.toLocaleString()\n",
        "  document.getElementById('r-addons').textContent='₦'+addons.toLocaleString()\n",
        "  document.getElementById('r-total').textContent='₦'+(base+distFee+weightFee+addons).toLocaleString()\n",
        "}\n",
        "calcPrice()\n",
