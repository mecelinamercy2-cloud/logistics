        "  document.getElementById('result-meta').innerHTML=data.meta.map(m=>`\n",
        "    <div class=\"meta-item\"><label>${m.label}</label><span>${m.val}</span></div>\n",
        "  `).join('')\n",
        "\n",
        "  result.classList.add('show')\n",
        "}\n",
